@using PagedList
@using PagedList.Mvc
@using Microsoft.AspNet.Identity
@model PagedList.IPagedList<ShippingMark.Models.ChiTietHangHoa>

@{
    ViewBag.Title = "Danh sách Chi Tiết Hàng Hóa";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">@ViewBag.Title</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("User"))
    {
        @Html.ActionLink("Tạo Thông Báo Mới", "QuickCreate", "ThongBaoXuatHangs", null, new { @class = "btn btn-primary" })        
    }
    <div class="alert alert-info me-3 mb-0 py-2 px-3">
        <p class="mb-0">
            <i class="bi bi-info-circle me-1"></i>
            Tổng số dòng in: <strong>@ViewBag.PrintedCount</strong> |
            Tổng số Serial: <strong>@ViewBag.TotalNumSerial</strong>
        </p>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>Hành động</th>
                <th>MODEL</th>
                <th>PO</th>                
                <th>Trạng thái in</th>
                <th>Ngày tạo(dd/MM/yyyy)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
            <tr class="@(item.UsingPrint == true ? "table-success" : "")">
                <td>
                    <a href="@Url.Action("Details", "ChiTietHangHoas", new { id = item.ID })" class="btn btn-info btn-sm me-1">Chi tiết</a>
                    @if (User.IsInRole("Admin") || User.IsInRole("User"))
                    {
                        <a href="@Url.Action("Edit", "ChiTietHangHoas", new { id = item.ID })" class="btn btn-warning btn-sm me-1">Sửa</a>
                        <a href="@Url.Action("UpdateReprint", "ChiTietHangHoas", new { id = item.ID })" class="btn btn-outline-success btn-sm me-1">Cập nhật SL In</a>
                        if (item.UsingPrint != true)
                        {
                            using (Html.BeginForm("ConfirmPrint", "ChiTietHangHoas", FormMethod.Post, new { @style = "display:inline-block;" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("id", item.ID)
                                <button type="submit" class="btn btn-primary btn-sm me-1">Xác nhận Đã in</button>
                            }
                        }
                    }
                </td>
                <td>@item.MODEL</td>
                <td>@item.ThongBaoXuatHang.PoNo</td>                
                <td>
                    @if (item.UsingPrint == true)
                    {
                        <span class="text-success fw-bold">Đã in</span>
                    }
                    else
                    {
                        <span class="text-danger">Chưa in</span>
                    }
                </td>
                <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>
            </tr>
            }
        </tbody>
    </table>
</div>

<div class="text-center">
    Trang @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) của @Model.PageCount
    @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions
{
    UlElementClasses = new[] { "pagination", "justify-content-center", "" },
    LiElementClasses = new[] { "page-item", "me-3" },
})
</div>

