@model ShippingMark.Models.IFT
@{
    ViewBag.Title = "Xác nhận xóa";
}

<h2 class="mb-4">Xác nhận xóa</h2>
<h4 class="text-danger">Bạn có chắc chắn muốn xóa bản ghi này không?</h4>
<hr />

<div class="container">
    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <i class="bi bi-info-circle me-2"></i> Thông tin chi tiết
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.REFNO)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.REFNO)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PoNo)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.PoNo)</dd>

                @* Thêm các trường khác cần hiển thị *@

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreatedBy)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedBy)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreatedDate)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedDate)</dd>
            </dl>
        </div>
    </div>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="mt-4">
        <button type="submit" class="btn btn-danger me-2">
            <i class="bi bi-trash"></i> Xóa
        </button>
        @Html.ActionLink("Hủy bỏ và trở về danh sách", "Index", null, new { @class = "btn btn-secondary" })
    </div>
}