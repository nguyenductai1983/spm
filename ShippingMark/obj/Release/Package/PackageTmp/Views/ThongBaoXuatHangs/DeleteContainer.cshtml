@model ShippingMark.Models.Container

@{
    ViewBag.Title = "Xác nhận xóa Container";
}

<h2>@ViewBag.Title</h2>
<h3 class="text-danger">Bạn có chắc chắn muốn xóa dòng này khỏi phiếu không?</h3>
<hr />

<div>
    <dl class="dl-horizontal">
        <dt>Container số</dt>
        <dd>@Html.DisplayFor(model => model.ContainerSo)</dd>

        <dt>Model</dt>
        <dd>@Html.DisplayFor(model => model.ChiTietHangHoa.MODEL)</dd>

        <dt>Số lượng</dt>
        <dd>@Html.DisplayFor(model => model.SoLuong)</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <div class="form-actions no-color">
            <input type="submit" value="Xóa" class="btn btn-danger" /> |
            @Html.ActionLink("Hủy", "ManageContainers", new { id = Model.ThongBaoXuatHang_ID })
        </div>
    }
</div>
