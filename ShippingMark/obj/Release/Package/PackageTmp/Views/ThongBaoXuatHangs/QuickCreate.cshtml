@model ShippingMark.Models.TaoThongBaoViewModel
@using ShippingMark.Models

@{
    // Tự động thay đổi tiêu đề và action của form dựa trên việc đang Sửa hay Tạo mới
    ViewBag.Title = Model.ID > 0 ? "Chỉnh Sửa Thông Báo" : "Bước 1: Tạo Phiếu & Chi Tiết Hàng Hóa";
}

<h2 class="text-center text-primary mb-4">@ViewBag.Title</h2>

@using (Html.BeginForm(Model.ID > 0 ? "Edit" : "QuickCreate", "ThongBaoXuatHangs", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    if (Model.ID > 0)
    {
        @Html.HiddenFor(model => model.ID)
    }

    <!-- ====================================================== -->
    <!-- PHẦN 1: NỘI DUNG CHUNG -->
    <!-- ====================================================== -->
    <div class="card shadow-sm mb-4">
        <div class="card-header">PHẦN 1: NỘI DUNG CHUNG</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    @Html.LabelFor(model => model.KhachHangID, htmlAttributes: new { @class = "form-label" })
                    @Html.DropDownListFor(model => model.KhachHangID, Model.KhachHangList, "--- Chọn khách hàng ---", new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.KhachHangID, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-6">
                    @Html.LabelFor(model => model.HangHoaID, htmlAttributes: new { @class = "form-label" })
                    @Html.DropDownListFor(model => model.HangHoaID, Model.HangHoaList, "--- Chọn danh mục hàng ---", new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.HangHoaID, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-6">
                    @Html.LabelFor(model => model.LoaiHang, htmlAttributes: new { @class = "form-label" })
                    @Html.EditorFor(model => model.LoaiHang, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.LoaiHang, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-6">
                    @Html.LabelFor(model => model.SoLuong, htmlAttributes: new { @class = "form-label" })
                    @Html.EditorFor(model => model.SoLuong, new { htmlAttributes = new { @class = "form-control", type = "number" } })
                    @Html.ValidationMessageFor(model => model.SoLuong, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-6">
                    @Html.LabelFor(model => model.DonHang, htmlAttributes: new { @class = "form-label" })
                    @Html.EditorFor(model => model.DonHang, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.DonHang, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-6">
                    @Html.LabelFor(model => model.SoPO, htmlAttributes: new { @class = "form-label" })
                    @Html.EditorFor(model => model.SoPO, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.SoPO, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-6">
                    @Html.LabelFor(model => model.NgayXuatHang, htmlAttributes: new { @class = "form-label" })
                    @Html.EditorFor(model => model.NgayXuatHang, new { htmlAttributes = new { @class = "form-control", @type = "date", @Value = Model.NgayXuatHang.ToString("yyyy-MM-dd") } })
                    @Html.ValidationMessageFor(model => model.NgayXuatHang, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-6">
                    @Html.LabelFor(model => model.ETD, htmlAttributes: new { @class = "form-label" })
                    @Html.EditorFor(model => model.ETD, new { htmlAttributes = new { @class = "form-control", @type = "date", @Value = Model.ETD.ToString("yyyy-MM-dd") } })
                    @Html.ValidationMessageFor(model => model.ETD, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>
    </div>

    <!-- PHẦN 2: CHI TIẾT HÀNG HÓA -->
    <div class="card shadow-sm mb-4">
        <div class="card-header">PHẦN 2: CHI TIẾT HÀNG HÓA</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="chiTietTable">
                    <thead>
                        <tr>
                            <th>MODEL</th>
                            <th>SIZE</th>
                            <th>Số lượng</th>
                            <th>Loại ĐG</th>
                            <th>NW</th>
                            <th>GW</th>
                            <th>Dài</th>
                            <th>Rộng</th>
                            <th>Cao</th>
                            <th>Màu</th>
                            <th>Nội dung MR</th>
                            <th>Lô</th>
                            <th>QUANTITY</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ChiTietList != null)
                        {
                            for (int i = 0; i < Model.ChiTietList.Count; i++)
                            {
                        <tr>
                            @Html.HiddenFor(m => m.ChiTietList[i].ID)
                            <td>@Html.TextBoxFor(m => m.ChiTietList[i].MODEL, new { @class = "form-control" })</td>
                            <td>@Html.TextBoxFor(m => m.ChiTietList[i].SIZE, new { @class = "form-control" })</td>
                            <td>@Html.TextBoxFor(m => m.ChiTietList[i].SoLuongThamKhao, new { @class = "form-control" })</td>
                            <td>@Html.EnumDropDownListFor(m => m.ChiTietList[i].SelectedTypeNum, new { @class = "form-control" })</td>
                            <td>@Html.TextBoxFor(m => m.ChiTietList[i].NW, new { @class = "form-control" })</td>
                            <td>@Html.TextBoxFor(m => m.ChiTietList[i].GW, new { @class = "form-control" })</td>
                            <td>@Html.TextBoxFor(m => m.ChiTietList[i].Dai, new { @class = "form-control", type = "number", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.ChiTietList[i].Rong, new { @class = "form-control", type = "number", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.ChiTietList[i].Cao, new { @class = "form-control", type = "number", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.ChiTietList[i].COLOR, new { @class = "form-control" })</td>
                            <td>@Html.TextBoxFor(m => m.ChiTietList[i].ExtendedContent, new { @class = "form-control" })</td>
                            <td>@Html.TextBoxFor(m => m.ChiTietList[i].LotNo, new { @class = "form-control" })</td>
                            <td>@Html.TextBoxFor(m => m.ChiTietList[i].QUANTITY, new { @class = "form-control" })</td>
                            <td class="text-center">
                                <button type="button" class="btn btn-danger btn-sm" onclick="deleteRow(this)">Xóa</button>
                            </td>
                        </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <button type="button" class="btn btn-success" id="addChiTietRow">Thêm chi tiết</button>
            <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#excelImportModal">
                Nhập từ Excel
            </button>
        </div>
    </div>
    @Html.ValidationSummary(false, "", new { @class = "alert alert-danger" })
    <div class="text-center">
        <button type="submit" class="btn btn-primary btn-lg">Lưu và Tiếp tục</button>
        @Html.ActionLink("Quay lại", "Index", null, new { @class = "btn btn-secondary btn-lg" })
    </div>
}
<table style="display:none">
    <tr class="hiding">
        <td>
            <input type="hidden" name="ChiTietList.Index" value="!INDEX!" />
            <input type="hidden" name="ChiTietList[!INDEX!].ID" value="0" />
        </td>
    </tr>
    <tr id="chiTietTemplateRow">
        <td><input class="form-control" type="text" name="ChiTietList[!INDEX!].MODEL" /></td>
        <td><input class="form-control" type="text" name="ChiTietList[!INDEX!].SIZE" /></td>
        <td><input class="form-control" type="text" name="ChiTietList[!INDEX!].SoLuongThamKhao" /></td>
        <td>@Html.DropDownList("ChiTietList[!INDEX!].SelectedTypeNum", new SelectList(Enum.GetValues(typeof(TypeNum))), new { @class = "form-control" })</td>
        <td><input class="form-control" type="text" name="ChiTietList[!INDEX!].NW" /></td>
        <td><input class="form-control" type="text" name="ChiTietList[!INDEX!].GW" /></td>
        <td><input class="form-control" type="number" step="0.01" name="ChiTietList[!INDEX!].Dai" /></td>
        <td><input class="form-control" type="number" step="0.01" name="ChiTietList[!INDEX!].Rong" /></td>
        <td><input class="form-control" type="number" step="0.01" name="ChiTietList[!INDEX!].Cao" /></td>
        <td><input class="form-control" type="text" name="ChiTietList[!INDEX!].COLOR" /></td>
        <td><input class="form-control" type="text" name="ChiTietList[!INDEX!].ExtendedContent" /></td>
        <td><input class="form-control" type="text" name="ChiTietList[!INDEX!].LotNo" /></td>
        <td><input class="form-control" type="text" name="ChiTietList[!INDEX!].QUANTITY" /></td>
        <td class="text-center">
            <button type="button" class="btn btn-danger btn-sm" onclick="deleteRow(this)">Xóa</button>
        </td>
    </tr>
</table>
<div class="modal fade" id="excelImportModal" tabindex="-1" aria-labelledby="excelImportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="excelImportModalLabel">Dán dữ liệu từ Excel</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Sao chép các cột từ Excel theo đúng thứ tự sau và dán vào ô bên dưới:</p>
                <p><code>MODEL | SIZE | Số lượng | Loại ĐG (giá trị số) | NW | GW | Dài | Rộng | Cao | Màu | Nội dung MR | Lô | QUANTITY</code></p>
                <textarea id="excelPasteArea" class="form-control" rows="15" placeholder="Dán dữ liệu của bạn vào đây..."></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="processPasteData">Thêm Dữ Liệu</button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>       

        function updateRowIndexes() {
            const tableBody = document.getElementById('chiTietTable').getElementsByTagName('tbody')[0];
            const rows = tableBody.getElementsByTagName('tr');
            for (let i = 0; i < rows.length; i++) {
                const row = rows[i];
                row.querySelectorAll('input, select').forEach(control => {
                    if (control.name) {
                        control.name = control.name.replace(/\[\d+\]/, `[${i}]`);
                    }
                });
            }
        }

        function deleteRow(btn) {
            btn.closest('tr').remove();
            updateRowIndexes();
        }

        function addRowWithData(data) {
            const tableBody = document.getElementById('chiTietTable').getElementsByTagName('tbody')[0];
            const templateRow = document.getElementById('chiTietTemplateRow');
            const newIndex = tableBody.getElementsByTagName('tr').length;

            const newRow = tableBody.insertRow();
            newRow.innerHTML = templateRow.innerHTML.replace(/!INDEX!/g, newIndex);

            const inputs = newRow.querySelectorAll('input, select');

            if (data) {
                // === BẮT ĐẦU PHẦN GỠ LỖI ===
                console.log("Dữ liệu thô từ Excel cho dòng này:", data);

                let soLuong = '0';
                let selectedTypeNum = 0; // Mặc định là Cuộn

                // Đọc chuỗi từ cột Số kiện (index 2) và Số cuộn (index 3) một cách an toàn
                const packageQtyStr = (data[2] || "").trim();
                const rollQtyStr = (data[3] || "").trim();
                console.log(`Đã đọc chuỗi -> Số kiện: '${packageQtyStr}', Số cuộn: '${rollQtyStr}'`);

                // Chuyển đổi chuỗi thành số
                const packageQty = parseInt(packageQtyStr, 10) || 0;
                const rollQty = parseInt(rollQtyStr, 10) || 0;
                console.log(`Sau khi chuyển đổi -> packageQty: ${packageQty}, rollQty: ${rollQty}`);

                if (packageQty > 0) {
                    soLuong = packageQty.toString();
                    selectedTypeNum = 1;
                    console.log("==> Đã xác định là PACKAGENO");
                } else if (rollQty > 0) {
                    soLuong = rollQty.toString();
                    selectedTypeNum = 0;
                    console.log("==> Đã xác định là ROLLNO");
                }
                // === KẾT THÚC PHẦN GỠ LỖI ===

                inputs[0].value = data[0] || '';
                inputs[1].value = data[1] || '';
                inputs[2].value = soLuong;
                const selectElement = inputs[3];
                selectElement.selectedIndex = selectedTypeNum;
                inputs[4].value = data[4] || '';
                inputs[5].value = data[5] || '';
                inputs[6].value = data[6] || '';
                inputs[7].value = data[7] || '';
                inputs[8].value = data[8] || '';
                inputs[9].value = data[9] || '';
                inputs[10].value = data[10] || '';
                inputs[11].value = data[11] || '';
                inputs[12].value = data[12] || '';
            }
        }

        document.getElementById('addChiTietRow').addEventListener('click', function () {
            addRowWithData(null);
            updateRowIndexes();
        });

        document.getElementById('processPasteData').addEventListener('click', function () {
            const pasteData = document.getElementById('excelPasteArea').value.trim();
            if (!pasteData) {
                alert('Vui lòng dán dữ liệu vào ô.');
                return;
            }
            const rows = pasteData.split('\n');
            rows.forEach(rowText => {
                if (rowText.trim() !== '') {
                    const cells = rowText.split('\t');
                    addRowWithData(cells);
                }
            });
            updateRowIndexes();
            document.getElementById('excelPasteArea').value = '';
            var excelModal = bootstrap.Modal.getInstance(document.getElementById('excelImportModal'));
            excelModal.hide();
            // alert("Đã thêm dữ liệu thành công!"); // Tạm thời tắt thông báo này để dễ xem console
        });
    </script>
}
