@model ShippingMark.Models.ManageContainersViewModel

@{
    ViewBag.Title = "Bước 2: Sắp Xếp Hàng Lên Container";
}

<h2 class="text-center text-primary mb-4">@ViewBag.Title</h2>

<!-- ====================================================== -->
<!-- THÔNG TIN TÓM TẮT -->
<!-- ====================================================== -->
<div class="card shadow-sm mb-4">
    <div class="card-header">THÔNG TIN PHIẾU</div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">Khách hàng:</dt>
            <dd class="col-sm-4">@Model.ThongBaoInfo.KhachHangName</dd>

            <dt class="col-sm-2">Danh mục:</dt>
            <dd class="col-sm-4">@Model.ThongBaoInfo.DanhMucName</dd>

            <dt class="col-sm-2">Số PO:</dt>
            <dd class="col-sm-4">@Model.ThongBaoInfo.SoPO</dd>

            <dt class="col-sm-2">REFNO:</dt>
            <dd class="col-sm-4">@Model.ThongBaoInfo.REFNO</dd>
        </dl>
    </div>
</div>

<!-- ====================================================== -->
<!-- DANH SÁCH CONTAINER ĐÃ THÊM -->
<!-- ====================================================== -->
<div class="card shadow-sm mb-4">
    <div class="card-header">DANH SÁCH CONTAINER ĐÃ SẮP XẾP</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Container số</th>
                        <th>Kích cỡ</th>
                        <th>Model</th>
                        <th>Số lượng</th>
                        <th>STT Từ - Đến</th>
                        <th>Ghi chú</th>
                        <th style="width: 150px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ExistingContainers)
                    {
                        <tr>
                            <td>@item.ContainerSo</td>
                            <td>@item.KichCo</td>
                            <td>@item.ModelName</td>
                            <td>@item.SoLuong</td>
                            <td>@item.TuDen</td>
                            <td>@item.GhiChu</td>
                            <td>
                                <a href="@Url.Action("EditContainer", new { id = item.ContainerID })" class="btn btn-sm btn-warning">Sửa</a>
                                <a href="@Url.Action("DeleteContainer", new { id = item.ContainerID })" class="btn btn-sm btn-danger">Xóa</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.ExistingContainers.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center">Chưa có container nào được thêm.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ====================================================== -->
<!-- FORM THÊM CONTAINER MỚI -->
<!-- ====================================================== -->
<div class="card shadow-sm mb-4">
    <div class="card-header">THÊM MỚI CONTAINER</div>
    <div class="card-body">
        @using (Html.BeginForm("ManageContainers", "ThongBaoXuatHangs", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.AddContainerForm.ThongBaoID)

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    @Html.LabelFor(model => model.AddContainerForm.ContainerSo, new { @class = "form-label" })
                    @Html.EditorFor(model => model.AddContainerForm.ContainerSo, new { htmlAttributes = new { @class = "form-control" } })
                </div>
                <div class="col-md-2">
                    @Html.LabelFor(model => model.AddContainerForm.KichCo, new { @class = "form-label" })
                    @Html.EditorFor(model => model.AddContainerForm.KichCo, new { htmlAttributes = new { @class = "form-control" } })
                </div>
                <div class="col-md-2">
                    @Html.LabelFor(model => model.AddContainerForm.ChiTietHangHoa_ID, "Model", new { @class = "form-label" })
                    @Html.DropDownListFor(model => model.AddContainerForm.ChiTietHangHoa_ID, Model.AddContainerForm.AvailableModelsList, "--- Chọn Model ---", new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.AddContainerForm.ChiTietHangHoa_ID, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-1">
                    @Html.LabelFor(model => model.AddContainerForm.SoLuong, new { @class = "form-label" })
                    @Html.EditorFor(model => model.AddContainerForm.SoLuong, new { htmlAttributes = new { @class = "form-control" } })
                </div>
                <div class="col-md-1">
                    @Html.LabelFor(model => model.AddContainerForm.Tu, new { @class = "form-label" })
                    @Html.EditorFor(model => model.AddContainerForm.Tu, new { htmlAttributes = new { @class = "form-control" } })
                </div>
                <div class="col-md-1">
                    @Html.LabelFor(model => model.AddContainerForm.Den, new { @class = "form-label" })
                    @Html.EditorFor(model => model.AddContainerForm.Den, new { htmlAttributes = new { @class = "form-control" } })
                </div>
                <div class="col-md-2">
                    @Html.LabelFor(model => model.AddContainerForm.GhiChu, new { @class = "form-label" })
                    @Html.EditorFor(model => model.AddContainerForm.GhiChu, new { htmlAttributes = new { @class = "form-control" } })
                </div>
                <div class="col-md-1 align-self-end">
                    <button type="submit" class="btn btn-success w-100">Thêm</button>
                </div>
            </div>
        }
    </div>
</div>

<div class="text-center mt-4">
    @Html.ActionLink("Hoàn tất và Quay về Danh sách", "Index", "ThongBaoXuatHangs", null, new { @class = "btn btn-primary btn-lg" })
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

