@model ShippingMark.Models.ThongBaoXuatHang

@{
    Layout = null; // Rất quan trọng: không dùng layout chung của website
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Thông Báo Xuất Hàng - @Model.PoNo</title>
    <style>
        body {
            font-family: 'Times New Roman', Times, serif;
            font-size: 11pt;
        }

        .container {
            width: 98%;
            margin: auto;
        }

        .info-table {
            width: 100%;
            margin-bottom: 15px;
            border-collapse: collapse;
        }

            .info-table td {
                padding: 3px;
                vertical-align: top;
            }

        .main-table {
            width: 100%;
            border-collapse: collapse;
            text-align: center;
            font-size: 10pt;
        }

            .main-table th, .main-table td {
                border: 1px solid black;
                padding: 4px;
                vertical-align: middle;
            }

            .main-table th {
                background-color: #f2f2f2;
            }

        .total-row td {
            font-weight: bold;
        }

        .text-left {
            text-align: left;
        }

        .text-red {
            color: red;
        }

        .group-header {
            font-weight: bold;
            text-align: left;
            padding: 15px 0 5px 0;
            font-size: 12pt;
        }

        .footer-container {
            margin-top: 50px;
        }

        .footer-table {
            width: 100%;
            border: none;
        }

        .footer-left {
            width: 50%;
            text-align: left;
            vertical-align: top;
            font-weight: bold;
            font-style: italic;
        }

        .footer-right {
            width: 50%;
            text-align: center;
            vertical-align: top;
        }

        /* CSS cho các nút chức năng */
        .button-container {
            padding: 10px 20px;
            text-align: right;
            position: fixed;
            top: 10px;
            right: 20px;
            z-index: 100;
        }

        .action-button {
            background-color: #007bff;
            color: white;
            padding: 10px 15px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
            text-decoration: none;
            margin-left: 10px;
        }

            .action-button:hover {
                background-color: #0056b3;
            }

        /* Tự động ẩn các nút khi in */
        @@media print {
            .button-container {
                display: none !important;
            }
        }
    </style>
</head>

<body>
    <div class="button-container">
        <button class="action-button" onclick="window.print()">🖨️ In Trang Này</button>
        <a href="@Url.Action("Print", new { id = Model.ID })" class="action-button">📄 Tải PDF</a>
    </div>

    <div class="container">
        <table style="width: 100%; border: none; margin-bottom: 20px;">
            <tr>
                <td style="width: 20%; text-align: left; border: none;">
                    <img src="@Url.Content("~/Content/images/logo.png")" alt="Logo" style="max-width: 180px; max-height: 90px;" />
                </td>
                <td style="width: 60%; text-align: center; border: none; vertical-align: middle;">
                    <h2 style="font-size: 20pt; margin: 0; font-weight: bold;">THÔNG BÁO XUẤT HÀNG</h2>
                </td>
                <td style="width: 20%; border: none;"></td>
            </tr>
        </table>

        <table class="info-table">
            <tr>
                <td style="width:15%;"><b>Loại hàng:</b></td>
                <td style="width:35%;">@Model.LoaiHang</td>
                <td style="width:20%;"><b>Tổng số kiện/cuộn:</b></td>
                <td style="width:30%;">
                    @{
                        var totalPackagesInfo = Model.Containers.Where(c => c.IFT.SelectedTypeNum == ShippingMark.Models.TypeNum.PACKAGENO).Sum(c => int.Parse(c.SoLuong ?? "0"));
                        var totalRollsInfo = Model.Containers.Where(c => c.IFT.SelectedTypeNum == ShippingMark.Models.TypeNum.ROLLNO).Sum(c => int.Parse(c.SoLuong ?? "0"));
                    }
                    @if (totalPackagesInfo > 0)
                    {
                        <b>@totalPackagesInfo kiện</b>
                    }
                    @if (totalRollsInfo > 0)
                    {
                        <b>@totalRollsInfo cuộn</b>
                    }
                </td>
            </tr>
            <tr>
                <td><b>Đơn hàng:</b></td>
                <td>@Model.REFNO</td>
                <td><b>Ngày xuất hàng dự kiến:</b></td>
                <td class="text-red"><b>@Model.Ngaydukien.Value.ToString("d/M/yyyy")</b></td>
            </tr>
            <tr>
                <td><b>Số PO:</b></td>
                <td>@Model.PoNo</td>
                <td><b>ETD:</b></td>
                <td class="text-red"><b>@Model.NgayETD.Value.ToString("d/M/yyyy")</b></td>
            </tr>
        </table>

        <table class="main-table">
            <thead>
                <tr>
                    <th rowspan="2">Model</th>
                    <th rowspan="2">Kích thước lưới</th>
                    <th rowspan="2">Số kiện</th>
                    <th rowspan="2">Số cuộn</th>
                    <th colspan="2">Trọng lượng (cuộn/kgs)</th>
                    <th colspan="3">Kích thước cuộn (m)</th>
                    <th rowspan="2">Màu (Color)</th>
                    <th rowspan="2">Nội dung mở rộng</th>
                </tr>
                <tr>
                    <th>Net weight</th>
                    <th>Gross weight</th>
                    <th>Dài</th>
                    <th>Rộng</th>
                    <th>Cao</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var groupedByIFT = Model.Containers.GroupBy(c => c.IFT);
                    var totalPackages = 0;
                    var totalRolls = 0;
                    foreach (var container in Model.Containers)
                    {
                        var quantity = int.Parse(container.SoLuong ?? "0");
                        if (container.IFT.SelectedTypeNum == ShippingMark.Models.TypeNum.PACKAGENO) { totalPackages += quantity; }
                        else { totalRolls += quantity; }
                    }
                }
                @foreach (var group in groupedByIFT)
                {
                    var ift = group.Key;
                    int soLuong = group.Sum(c => int.Parse(c.SoLuong ?? "0"));
                    <tr>
                        <td class="text-left">@ift.MODEL</td>
                        <td>@ift.SIZE</td>
                        <td>@(ift.SelectedTypeNum == ShippingMark.Models.TypeNum.PACKAGENO ? soLuong.ToString() : "0")</td>
                        <td>@(ift.SelectedTypeNum == ShippingMark.Models.TypeNum.ROLLNO ? soLuong.ToString() : "0")</td>
                        <td>@ift.NW</td>
                        <td>@ift.GW</td>
                        <td>@ift.Dai</td>
                        <td>@ift.Rong</td>
                        <td>@ift.Cao</td>
                        <td>@ift.COLOR</td>
                        <td class="text-red">@ift.TypeSuffix</td>
                    </tr>
                }
                <tr class="total-row">
                    <td colspan="2">TỔNG CỘNG</td>
                    <td>@totalPackages Kiện</td>
                    <td>@totalRolls Cuộn</td>
                    <td colspan="7"></td>
                </tr>
            </tbody>
        </table>

        <div class="group-header">Xếp lên container như sau:</div>

        <table class="main-table">
            <thead>
                <tr>
                    <th rowspan="2">Container số</th>
                    <th rowspan="2">Kích cỡ container</th>
                    <th rowspan="2">Số lượng</th>
                    <th rowspan="2">Model</th>
                    <th colspan="2">STT Kiện/Cuộn</th>
                    <th rowspan="2" style="width: 30%;">Ghi chú</th>
                </tr>
                <tr>
                    <th>Từ</th>
                    <th>Đến</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var groupedByContainer = Model.Containers.GroupBy(c => c.ContainerSo);                    
                }
                @foreach (var group in groupedByContainer)
                {
                    var firstItemInGroup = true;
                    foreach (var container in group)
                    {
                        var startSerial = 0;
                        var soLuongItem = 0;
                        int.TryParse(container.IFT.StartSerial, out startSerial);
                        int.TryParse(container.SoLuong, out soLuongItem);
                        var endSerial = (startSerial > 0 && soLuongItem > 0) ? (startSerial + soLuongItem - 1) : startSerial;

                        <tr>
                            @if (firstItemInGroup)
                            {
                                <td rowspan="@group.Count()">@container.ContainerSo</td>
                                <td rowspan="@group.Count()">@container.KichCo</td>
                            }
                            <td>@container.SoLuong</td>
                            <td class="text-left">@container.IFT.MODEL</td>
                            <td>@startSerial</td>
                            <td>@endSerial</td>
                            <td class="text-left">@container.GhiChu</td>
                        </tr>
                        firstItemInGroup = false;
                    }
                }
            </tbody>
        </table>

        <div class="footer-container">
            <table class="footer-table">
                <tr>
                    <td class="footer-left">
                        - BP. Kho.<br />
                        - PX. May.<br />
                        - BP. thống kê.<br />
                        - BP. XNK.<br />
                        - Lưu
                    </td>
                    <td class="footer-right">
                        <i>@DateTime.Now.ToString("'Ngày' dd 'tháng' MM 'năm' yyyy")</i><br /><br />
                        <b>Người lập</b>
                        <br /><br /><br /><br />
                    </td>
                </tr>
            </table>
        </div>
    </div>
</body>
</html>