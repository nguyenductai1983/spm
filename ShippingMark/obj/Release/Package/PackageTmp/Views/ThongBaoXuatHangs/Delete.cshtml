@model ShippingMark.Models.ThongBaoXuatHang

@{
    ViewBag.Title = "Xác nhận Xóa";
}

<h2>@ViewBag.Title</h2>

<h3>Bạn có chắc chắn muốn xóa phiếu thông báo này không?</h3>
<p class="text-danger">Hành động này sẽ xóa vĩnh viễn phiếu và tất cả các chi tiết liên quan.</p>
<div>
    <h4>Thông tin phiếu</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>@Html.DisplayNameFor(model => model.KhachHang.Name)</dt>
        <dd>@Html.DisplayFor(model => model.KhachHang.Name)</dd>

        <dt>@Html.DisplayNameFor(model => model.PoNo)</dt>
        <dd>@Html.DisplayFor(model => model.PoNo)</dd>

        <dt>@Html.DisplayNameFor(model => model.REFNO)</dt>
        <dd>@Html.DisplayFor(model => model.REFNO)</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-actions no-color">
            <input type="submit" value="Xóa" class="btn btn-danger" /> |
            @Html.ActionLink("Hủy và Quay lại", "Index")
        </div>
    }
</div>
