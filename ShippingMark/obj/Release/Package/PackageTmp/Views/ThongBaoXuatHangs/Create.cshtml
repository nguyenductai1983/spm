@model ShippingMark.Models.ThongBaoXuatHangViewModel

@{
    ViewBag.Title = "Tạo Thông Báo Xuất Hàng";
}

<h2>@ViewBag.Title</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

<div class="form-horizontal">
    <h4>Thông tin chung</h4>
    <hr />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="row">
        @* Cột bên trái *@
        <div class="col-md-6">
            <div class="form-group">
                @Html.LabelFor(model => model.ThongBao.LoaiHang, htmlAttributes: new { @class = "control-label col-md-4" })
                <div class="col-md-8">
                    @Html.EditorFor(model => model.ThongBao.LoaiHang, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.ThongBao.LoaiHang, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.ThongBao.REFNO, htmlAttributes: new { @class = "control-label col-md-4" })
                <div class="col-md-8">
                    @Html.EditorFor(model => model.ThongBao.REFNO, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.ThongBao.REFNO, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.ThongBao.PoNo, htmlAttributes: new { @class = "control-label col-md-4" })
                <div class="col-md-8">
                    @Html.EditorFor(model => model.ThongBao.PoNo, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.ThongBao.PoNo, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>

        @* Cột bên phải *@
        <div class="col-md-6">
            <div class="form-group">
                @Html.LabelFor(model => model.ThongBao.Ngaydukien, htmlAttributes: new { @class = "control-label col-md-4" })
                <div class="col-md-8">
                    @Html.EditorFor(model => model.ThongBao.Ngaydukien, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.ThongBao.Ngaydukien, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.ThongBao.NgayETD, htmlAttributes: new { @class = "control-label col-md-4" })
                <div class="col-md-8">
                    @Html.EditorFor(model => model.ThongBao.NgayETD, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.ThongBao.NgayETD, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.ThongBao.GhiChu, htmlAttributes: new { @class = "control-label col-md-4" })
                <div class="col-md-8">
                    @Html.EditorFor(model => model.ThongBao.GhiChu, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.ThongBao.GhiChu, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>
    </div>

    <hr />
    <h4>Chi tiết Containers</h4>

    <table class="table" id="containerTable">
        <thead>
            <tr>
                <th>Model (Hàng hóa)</th>
                <th>Container số</th>
                <th>Kích cỡ</th>
                <th>Số lượng</th>
                <th>Ghi chú</th>
                <th style="width: 5%"></th>
            </tr>
        </thead>
        <tbody>
            @* Các dòng container sẽ được thêm vào đây bằng JavaScript *@
        </tbody>
        <tfoot>
            @* Đây là dòng mẫu ẩn, dùng để sao chép *@
            <tr id="templateRow" style="display: none;">
                <td>
                    @Html.DropDownList("tempId", Model.IFTList, "--- Chọn Model ---", new { @class = "form-control" })
                    <span class="text-danger field-validation-valid" data-valmsg-for="Containers[0].IFT_ID" data-valmsg-replace="true"></span>
                </td>
                <td><input class="form-control" type="text" /></td>
                <td><input class="form-control" type="text" /></td>
                <td><input class="form-control" type="text" /></td>
                <td><input class="form-control" type="text" /></td>
                <td><button type="button" class="btn btn-danger btn-sm remove-row">Xóa</button></td>
            </tr>
        </tfoot>
    </table>
    @Html.ActionLink("Tải lên Import Excel", "Import", "IFT", null, new { @class = "btn btn-success me-1" })
    <button type="button" id="addRow" class="btn btn-success">Thêm Container</button>

    <hr />
    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <input type="submit" value="Tạo Mới" class="btn btn-primary" />
            @Html.ActionLink("Quay lại Danh sách", "Index", null, new { @class = "btn btn-secondary" })
        </div>
    </div>
</div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            function updateRowIndices() {
                $('#containerTable tbody tr').each(function (index) {
                    $(this).find('select, input, span').each(function () {
                        if (this.name) {
                            this.name = this.name.replace(/\[\d+\]/, '[' + index + ']');
                        }
                        if (this.id) {
                            this.id = this.id.replace(/_\d+__/, '_' + index + '__');
                        }
                        var valmsgFor = $(this).attr('data-valmsg-for');
                        if (valmsgFor) {
                            $(this).attr('data-valmsg-for', valmsgFor.replace(/\[\d+\]/, '[' + index + ']'));
                        }
                    });
                });
            }

            $('#addRow').click(function () {
                var newRow = $('#templateRow').clone();
                newRow.removeAttr('id');
                newRow.show();

                // Gán 'name' cho các control để Model Binding hoạt động
                newRow.find('select').attr('name', 'Containers[0].IFT_ID');
                var inputs = newRow.find('input');
                $(inputs[0]).attr('name', 'Containers[0].ContainerSo');
                $(inputs[1]).attr('name', 'Containers[0].KichCo');
                $(inputs[2]).attr('name', 'Containers[0].SoLuong');
                $(inputs[3]).attr('name', 'Containers[0].GhiChu');

                $('#containerTable tbody').append(newRow);
                updateRowIndices();

                // Kích hoạt lại validation cho form
                var form = $('form');
                form.removeData('validator');
                form.removeData('unobtrusiveValidation');
                $.validator.unobtrusive.parse(form);
            });

            $('#containerTable').on('click', '.remove-row', function () {
                $(this).closest('tr').remove();
                updateRowIndices();
            });
        });
    </script>
}