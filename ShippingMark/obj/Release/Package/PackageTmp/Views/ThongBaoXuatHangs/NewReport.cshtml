@model ShippingMark.Models.NewReportViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Thông Báo Xuất Hàng - @Model.PoNo</title>
    <style>
        body {
            font-family: 'Times New Roman', Times, serif;
            font-size: 11pt;
        }

        .container {
            width: 98%;
            margin: auto;
        }

        .info-table {
            width: 100%;
            margin-bottom: 15px;
            border-collapse: collapse;
        }

            .info-table td {
                padding: 3px;
                vertical-align: top;
            }

        .main-table {
            width: 100%;
            border-collapse: collapse;
            text-align: center;
            font-size: 10pt;
        }

            .main-table th, .main-table td {
                border: 1px solid black;
                padding: 4px;
                vertical-align: middle;
            }

            .main-table th {
                background-color: #f2f2f2;
            }

        .total-row td {
            font-weight: bold;
        }

        .text-left {
            text-align: left;
        }

        .text-red {
            color: red;
        }
        .text-green {
            color: green;
        }
        .group-header {
            font-weight: bold;
            text-align: left;
            padding: 15px 0 5px 0;
            font-size: 12pt;
        }

        .footer-container {
            margin-top: 50px;
        }

        .footer-table {
            width: 100%;
            border: none;
        }

        .footer-left {
            width: 50%;
            text-align: left;
            vertical-align: top;
            font-weight: bold;
            font-style: italic;
        }

        .footer-right {
            width: 50%;
            text-align: center;
            vertical-align: top;
        }

        .button-container {
            padding: 10px 20px;
            text-align: right;
            position: fixed;
            top: 10px;
            right: 20px;
            z-index: 100;
        }

        .action-button {
            background-color: #007bff;
            color: white;
            padding: 10px 15px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
            text-decoration: none;
            margin-left: 10px;
        }

            .action-button:hover {
                background-color: #0056b3;
            }

        @@media print {
            .button-container {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    @* === BỔ SUNG CÁC NÚT CHỨC NĂNG === *@
    <div class="button-container">
        <button class="action-button" onclick="window.print()">🖨️ In Trang Này</button>
        <a href="@Url.Action("NewPrint", new { id = Model.ID })" class="action-button">📄 Tải PDF</a>
    </div>

    <div class="container">
        <table style="width: 100%; border: none; margin-bottom: 20px;">
            <tr>
                <td style="width: 20%; text-align: left; border: none;">
                    <img src="@Url.Content("~/Content/images/logo.png")" alt="Logo" style="max-width: 180px; max-height: 90px;" />
                </td>
                <td style="width: 60%; text-align: center; border: none; vertical-align: middle;">
                    <h2 style="font-size: 20pt; margin: 0; font-weight: bold;">THÔNG BÁO XUẤT HÀNG</h2>
                </td>
                <td style="width: 20%; border: none;"></td>
            </tr>
        </table>

        <table class="info-table">
            <tr>
                <td style="width:15%;"><b>Loại hàng:</b></td>
                <td style="width:35%;">@Model.LoaiHang</td>
                <td style="width:20%;"><b>Tổng số kiện/cuộn:</b></td>
                <td style="width:30%;">
                    @{ // Dùng SelectMany để lấy tất cả các mặt hàng từ tất cả các container ra một danh sách phẳng
                                    var allContainerItems = Model.ContainerGroups.SelectMany(g => g.Items);

                                    // Tính tổng số kiện từ danh sách các mặt hàng trong container
                                    var totalPackages = allContainerItems
                                        .Where(item => item.SelectedTypeNum == ShippingMark.Models.TypeNum.PACKAGENO)
                                        .Sum(item => int.TryParse(item.SoLuong, out int num) ? num : 0);

                                    // Tính tổng số cuộn từ danh sách các mặt hàng trong container
                                    var totalRolls = allContainerItems
                                        .Where(item => item.SelectedTypeNum == ShippingMark.Models.TypeNum.ROLLNO)
                                        .Sum(item => int.TryParse(item.SoLuong, out int num) ? num : 0); }
                    @if (totalPackages > 0)
                    {<b>@totalPackages kiện</b>}
                    @if (totalRolls > 0)
                    {<b>@totalRolls cuộn</b>}
                </td>
            </tr>
            <tr>
                <td><b>Đơn hàng:</b></td>
                <td>@Model.REFNO</td>
                <td><b>Ngày dự kiến:</b></td>
                <td class="text-red"><b>@Model.NgaydukienString</b></td>
            </tr>
            <tr>
                <td><b>Số PO:</b></td>
                <td>@Model.PoNo</td>
                <td><b>ETD:</b></td>
                <td class="text-red"><b>@Model.NgayETDString</b></td>
            </tr>            
        <tr>
            <td class="text-green"><b>CUSTOMER:</b></td>
            <td>@Model.TenKhachHang</td>
            <td class="text-green"><b>COMMODITY:</b></td>
            <td>@Model.TenHangHoa</td>
        </tr>        
            
        </table>

        <table class="main-table">
            <thead>
                <tr>
                    <th rowspan="2">Model</th>
                    <th rowspan="2">Kích thước lưới</th>
                    <th rowspan="2">Số kiện</th>
                    <th rowspan="2">Số cuộn</th>
                    <th colspan="2">Trọng lượng (cuộn/kgs)</th>
                    <th colspan="3">Kích thước cuộn (m)</th>
                    <th rowspan="2">Màu (Color)</th>
                    <th rowspan="2">Nội dung mở rộng</th>
                    <th rowspan="2">LOT NO</th>
                </tr>
                <tr>
                    <th>Net weight</th>
                    <th>Gross weight</th>
                    <th>Dài</th>
                    <th>Rộng</th>
                    <th>Cao</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.ChiTietList)
                {
                <tr>
                    <td class="text-left">@item.MODEL</td>
                    <td>@item.SIZE</td>
                    <td>
                        @{ // Tính tổng số kiện cho model hiện tại từ dữ liệu container
                            var packagesForThisModel = Model.ContainerGroups
                                .SelectMany(g => g.Items)
                                .Where(c => c.ModelName == item.MODEL && c.SelectedTypeNum == ShippingMark.Models.TypeNum.PACKAGENO)
                                .Sum(c => int.TryParse(c.SoLuong, out int num) ? num : 0); }
                        @packagesForThisModel
                    </td>
                    <td>
                        @{ // Tính tổng số cuộn cho model hiện tại từ dữ liệu container
                            var rollsForThisModel = Model.ContainerGroups
                                .SelectMany(g => g.Items)
                                .Where(c => c.ModelName == item.MODEL && c.SelectedTypeNum == ShippingMark.Models.TypeNum.ROLLNO)
                                .Sum(c => int.TryParse(c.SoLuong, out int num) ? num : 0); }
                        @rollsForThisModel
                    </td>
                    <td>@item.NW</td>
                    <td>@item.GW</td>
                    <td>@item.Dai</td>
                    <td>@item.Rong</td>
                    <td>@item.Cao</td>
                    <td>@item.COLOR</td>
                    <td class="text-red">@item.ExtendedContent</td>
                    <td class="text-red">@item.LotNo</td>
                </tr>
                }
                <tr class="total-row">
                    <td colspan="2">TỔNG CỘNG</td>
                    <td>@totalPackages Kiện</td>
                    <td>@totalRolls Cuộn</td>
                    <td colspan="8"></td>
                </tr>
            </tbody>
        </table>

        <div class="group-header">Xếp lên container như sau:</div>

        <table class="main-table">
            <thead>
                <tr>
                    <th rowspan="2">Container số</th>
                    <th rowspan="2">Kích cỡ container</th>
                    <th rowspan="2">Số lượng</th>
                    <th rowspan="2">Model</th>
                    <th colspan="2">STT</th>
                    <th rowspan="2" style="width: 30%;">Ghi chú</th>
                </tr>
                <tr>
                    <th>Từ</th>
                    <th>Đến</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var group in Model.ContainerGroups)
                {
                    var isFirstItemInGroup = true;
                    foreach (var item in group.Items)
                    {
                        <tr>
                            @if (isFirstItemInGroup)
                            {
                                <td rowspan="@group.Items.Count()">@group.ContainerSo</td>
                                <td rowspan="@group.Items.Count()">@group.KichCo</td>
                            }
                            <td>@item.SoLuong</td>
                            <td class="text-left">@item.ModelName</td>
                            <td>@item.Tu</td>
                            <td>@item.Den</td>
                            <td class="text-left">@item.GhiChu</td>
                        </tr>
                        isFirstItemInGroup = false;
                    }
                }
            </tbody>
        </table>

        <div class="footer-container">
            <table class="footer-table">
                <tr>
                    <td class="footer-left">- BP. Kho.<br />- PX. May.<br />- BP. thống kê.<br />- BP. XNK.<br />- Lưu</td>
                    <td class="footer-right">
                        <i>@DateTime.Now.ToString("'Ngày' dd 'tháng' MM 'năm' yyyy")</i><br /><br />
                        <b>Người lập</b><br /><br /><br /><br />
                        <b>@Model.NguoiLapBaoCao</b>
                    </td>
                </tr>
            </table>
        </div>
    </div>
</body>

</html>