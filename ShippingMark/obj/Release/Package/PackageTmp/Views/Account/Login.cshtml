@using ShippingMark.Models
@model LoginViewModel
@{
    ViewBag.Title = "Đăng nhập";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card shadow-lg p-4">
            <h2 class="card-title text-center mb-4">
                <i class="bi bi-person-circle me-2"></i> @ViewBag.Title
            </h2>
            <div class="card-body">
                <section id="loginForm">
                    @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "row g-3", role = "form" }))
                    {
                        @Html.AntiForgeryToken()
                        <p class="text-muted text-center">Sử dụng tài khoản nội bộ để đăng nhập.</p>
                        <hr />
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="col-12">
                            @Html.LabelFor(m => m.UserName, "Tên đăng nhập hoặc Email", new { @class = "form-label" })
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", placeholder = "Nhập tên đăng nhập hoặc Email của bạn" })
                            </div>
                            @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger" })
                        </div>

                        <div class="col-12">
                            @Html.LabelFor(m => m.Password, "Mật khẩu", new { @class = "form-label" })
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-key"></i></span>
                                @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Nhập mật khẩu" })
                            </div>
                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input" })
                                @Html.LabelFor(m => m.RememberMe, "Ghi nhớ đăng nhập", new { @class = "form-check-label" })
                            </div>
                        </div>

                        <div class="col-12 text-center">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </button>
                        </div>

                        <div class="col-12 text-center">
                            <p class="mt-3 mb-0">
                                @Html.ActionLink("Đăng ký tài khoản mới", "Register")
                            </p>
                        </div>
                    }
                </section>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}