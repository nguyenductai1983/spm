@model ShippingMark.Models.EditProfileViewModel
@{
    ViewBag.Title = "Chỉnh sửa thông tin cá nhân";
}

<h2 class="mb-4">@ViewBag.Title</h2>

@using (Html.BeginForm("EditProfile", "Manage", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
{
    @Html.AntiForgeryToken()
    <h4>Cập nhật họ tên của bạn.</h4>
    <hr />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    <div class="form-group mb-3">
        @Html.LabelFor(m => m.FullName, new { @class = "col-md-2 form-label" })
        <div class="col-md-10">
            @Html.TextBoxFor(m => m.FullName, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger" })
        </div>
    </div>
    <div class="form-group mb-3">
        <div class="col-md-offset-2 col-md-10">
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
        </div>
    </div>
}

<div>
    @Html.ActionLink("Trở về trang quản lý", "Index")
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
