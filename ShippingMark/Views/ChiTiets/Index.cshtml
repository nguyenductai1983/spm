@using PagedList
@using PagedList.Mvc
@using Microsoft.AspNet.Identity
@model PagedList.IPagedList<ShippingMark.Models.IFT>
@{
    ViewBag.Title = "Danh sách IFT";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Danh sách SM</h2>
    <div class="d-flex align-items-center">
        @if (User.IsInRole("Admin") || User.IsInRole("User"))
        {
            <div class="mt-auto">
                <a href="@Url.Action("Create", "IFTs")" class="btn btn-success me-1">
                    <i class="bi bi-plus-circle me-1"></i> Tạo mới
                </a>
            </div>
        }
        <div class="mt-auto">
            @Html.ActionLink("Tải lên Import Excel", "Import", "IFT", null, new { @class = "btn btn-success me-1" })
        </div>
        <div class="alert alert-info me-3 mb-0 py-2 px-3">
            <p class="mb-0">
                <i class="bi bi-info-circle me-1"></i>
                Tổng số dòng in: <strong>@ViewBag.PrintedCount</strong> |
                Tổng số Serial: <strong>@ViewBag.TotalNumSerial</strong>
            </p>
        </div>

    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                @if (User.IsInRole("Admin") || User.IsInRole("User"))
                {
                    <th class="action-column">Hành động</th>
                }
                <th>@Html.DisplayNameFor(model => model.First().REFNO)</th>
                <th>@Html.DisplayNameFor(model => model.First().PoNo)</th>
                <th>@Html.DisplayNameFor(model => model.First().MODEL)</th>
                <th>@Html.DisplayNameFor(model => model.First().SIZE)</th>
                <th>@Html.DisplayNameFor(model => model.First().GW)</th>
                <th>@Html.DisplayNameFor(model => model.First().COLOR)</th>
                <th>@Html.DisplayNameFor(model => model.First().Type)</th>
                <th>@Html.DisplayNameFor(model => model.First().TypeSuffix)</th>
                <th>@Html.DisplayNameFor(model => model.First().usingPrint)</th>
                <th>@Html.DisplayNameFor(model => model.First().StartSerial)</th>
                <th>@Html.DisplayNameFor(model => model.First().NumSerial)</th>
                <th>@Html.DisplayNameFor(model => model.First().LotNo)</th>
                <th>@Html.DisplayNameFor(model => model.First().Customer)</th>
                <th>@Html.DisplayNameFor(model => model.First().QUANTITY)</th>
                <th>@Html.DisplayNameFor(model => model.First().COMMODITY)</th>
                <th>@Html.DisplayNameFor(model => model.First().CustomerCode)</th>
                <th>@Html.DisplayNameFor(model => model.First().CreatedBy)</th>
                <th>@Html.DisplayNameFor(model => model.First().CreatedDate)</th>
                <th>@Html.DisplayNameFor(model => model.First().LastModifiedBy)</th>
                <th>@Html.DisplayNameFor(model => model.First().LastModifiedDate)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.usingPrint ?? false ? "table-success" : "table-danger")">
                    @if (User.IsInRole("Admin") || User.IsInRole("User"))
                    {
                        <td>
                            <a href="@Url.Action("Edit", "IFTs", new { id = item.ID })" class="btn btn-warning btn-sm me-2">
                                <i class="bi bi-pencil-square me-1"></i>Sửa
                            </a>
                            <a href="@Url.Action("Details", "IFTs", new { id = item.ID })" class="btn btn-info btn-sm">
                                <i class="bi bi-info-circle me-1"></i>Chi tiết
                            </a>
                            @if (item.usingPrint != true)
                            {
                                using (Html.BeginForm("ConfirmPrint", "IFTs", FormMethod.Post, new { @style = "display:inline-block;" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("id", item.ID)
                                    <button type="submit" class="btn btn-primary btn-sm me-2">
                                        <i class="bi bi-printer me-1"></i> Đã in
                                    </button>
                                }
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <a href="@Url.Action("Delete", "IFTs", new { id = item.ID })" class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash me-1"></i> Xóa
                                </a>
                            }
                        </td>
                    }
                    <td>@Html.DisplayFor(modelItem => item.REFNO)</td>
                    <td>@Html.DisplayFor(modelItem => item.PoNo)</td>
                    <td>@Html.DisplayFor(modelItem => item.MODEL)</td>
                    <td>@Html.DisplayFor(modelItem => item.SIZE)</td>
                    <td>@Html.DisplayFor(modelItem => item.GW)</td>
                    <td>@Html.DisplayFor(modelItem => item.COLOR)</td>
                    <td>@Html.DisplayFor(modelItem => item.Type)</td>
                    <td>@Html.DisplayFor(modelItem => item.TypeSuffix)</td>
                    <td>
                        @if (item.usingPrint == true)
                        {
                            <span class="text-success"><i class="bi bi-check-circle-fill"></i> Đã in</span>
                        }
                        else
                        {
                            <span class="text-danger"><i class="bi bi-x-circle-fill"></i> Chưa in</span>
                        }
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.StartSerial)</td>
                    <td>@Html.DisplayFor(modelItem => item.NumSerial)</td>
                    <td>@Html.DisplayFor(modelItem => item.LotNo)</td>
                    <td>@Html.DisplayFor(modelItem => item.Customer)</td>
                    <td>@Html.DisplayFor(modelItem => item.QUANTITY)</td>
                    <td>@Html.DisplayFor(modelItem => item.COMMODITY)</td>
                    <td>@Html.DisplayFor(modelItem => item.CustomerCode)</td>
                    <td>@Html.DisplayFor(modelItem => item.CreatedBy)</td>
                    <td>@Html.DisplayFor(modelItem => item.CreatedDate)</td>
                    <td>@Html.DisplayFor(modelItem => item.LastModifiedBy)</td>
                    <td>@Html.DisplayFor(modelItem => item.LastModifiedDate)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="text-center">
    Trang @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) của @Model.PageCount
    @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions
{
    UlElementClasses = new[] { "pagination", "justify-content-center", "" },
    LiElementClasses = new[] { "page-item", "me-3" },
})
</div>
