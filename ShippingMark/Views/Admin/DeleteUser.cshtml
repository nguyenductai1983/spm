@model ShippingMark.Models.ApplicationUser
@{
    ViewBag.Title = "Xác nhận xóa người dùng";
}

<h2 class="mb-4">Xác nhận xóa người dùng</h2>
<h4 class="text-danger">Bạn có chắc chắn muốn xóa người dùng này không?</h4>
<hr />

<div class="card shadow-sm border-danger mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Tên đăng nhập</dt>
            <dd class="col-sm-9">@Model.UserName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>
        </dl>
    </div>
</div>

@using (Html.BeginForm("DeleteUser", "Admin", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.Hidden("userId", Model.Id)
    <button type="submit" class="btn btn-danger me-2">
        <i class="bi bi-trash me-1"></i> Xóa
    </button>
    @Html.ActionLink("Hủy bỏ và trở về danh sách", "UserList", null, new { @class = "btn btn-secondary" })
}