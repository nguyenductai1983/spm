@model ShippingMark.Models.ChiTietHangHoa
@{
    ViewBag.Title = "Tạo mới Chi Tiết Hàng Hóa";
}

<h2 class="mb-4">@ViewBag.Title</h2>
<hr />

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="row">
        @* Tạm thời các trường REFNO, PoNo sẽ nhập tay *@
        <div class="col-md-4 mb-3">
            @Html.LabelFor(model => model.REFNO, new { @class = "form-label" })
            @Html.EditorFor(model => model.REFNO, new { htmlAttributes = new { @class = "form-control" } })
        </div>
        <div class="col-md-4 mb-3">
            @Html.LabelFor(model => model.PoNo, new { @class = "form-label" })
            @Html.EditorFor(model => model.PoNo, new { htmlAttributes = new { @class = "form-control" } })
        </div>
        <div class="col-md-4 mb-3">
            @Html.LabelFor(model => model.MODEL, new { @class = "form-label" })
            @Html.EditorFor(model => model.MODEL, new { htmlAttributes = new { @class = "form-control" } })
        </div>
        @* Thêm các trường khác tương tự *@
    </div>

    <div class="row mt-4">
        <div class="col-12 text-center">
            <button type="submit" class="btn btn-primary me-2">Tạo mới</button>
            @Html.ActionLink("Trở về danh sách", "Index", null, new { @class = "btn btn-secondary" })
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
