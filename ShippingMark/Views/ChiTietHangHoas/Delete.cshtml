@model ShippingMark.Models.ChiTietHangHoa
@{
    ViewBag.Title = "Xác nhận xóa";
}

<h2 class="mb-4">@ViewBag.Title</h2>
<h4 class="text-danger">Bạn có chắc chắn muốn xóa chi tiết hàng hóa này không?</h4>
<hr />

<div class="card shadow-sm border-danger">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.MODEL)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.MODEL)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.SIZE)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.SIZE)</dd>
        </dl>
    </div>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="mt-4">
        <button type="submit" class="btn btn-danger me-2">Xóa</button>
        @Html.ActionLink("Hủy bỏ", "Index", null, new { @class = "btn btn-secondary" })
    </div>
}
